<?xml version="1.0" encoding="utf-8"?>
<!--
  Cleartext (unencrypted HTTP) is only permitted for the local development
  backend reached from the emulator (10.0.2.2) and host (localhost). Every other
  destination requires HTTPS. This replaces the app-wide
  android:usesCleartextTraffic="true", which would have allowed plain HTTP to any
  host — a needless attack surface for a release build.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
