# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Lock files (pnpm manages this)
package-lock.json
frontend/package-lock.json
backend/package-lock.json

# Build output
dist/
frontend/dist/
.vite/
frontend/.vite/

# SQLite database (contains user data — do not commit)
backend/meetngo.db
backend/meetngo.db-shm
backend/meetngo.db-wal

# Uploaded event images (user content — do not commit)
backend/uploads/*
!backend/uploads/.gitkeep

# Local env files
.env
.env.*
frontend/.env
frontend/.env.*
backend/.env
backend/.env.*

# Logs
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Claude Code local settings
.claude/settings.local.json

# Editor directories and files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# OS files
.DS_Store
Thumbs.db
