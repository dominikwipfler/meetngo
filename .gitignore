# Dependencies
node_modules/
backend/node_modules/

# Lock files (pnpm manages this)
package-lock.json
backend/package-lock.json

# Build output
dist/
.vite/
*.tsbuildinfo

# Heruntergeladene Kartenkacheln (Cache des Tile-Proxys, siehe routes/tiles.js)
backend/tiles-cache/

# Lokal generiertes JWT-Secret für die Entwicklung (siehe middleware/auth.js).
# Niemals committen — Produktion nutzt JWT_SECRET aus der Umgebung.
backend/.jwt-dev-secret

# SQLite database (contains user data — do not commit)
backend/meetngo.db
backend/meetngo.db-shm
backend/meetngo.db-wal

# Uploaded event images (user content — do not commit)
backend/uploads/*
!backend/uploads/.gitkeep
# …except the bundled seed images: app assets the backend serves as fallback
# event pictures (referenced by database.js / routes/events.js).
!backend/uploads/seed/
!backend/uploads/seed/**

# Local env files
.env
.env.*
backend/.env
backend/.env.*
!.env.example
!backend/.env.example

# Logs
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*


# Editor directories and files
.vscode/
.idea/
.claude/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# OS files
.DS_Store
Thumbs.db
