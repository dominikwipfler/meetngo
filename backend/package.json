{
  "name": "backend",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --ignore '*.db' --ignore '*.db-wal' --ignore '*.db-shm' --ignore 'uploads/' server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.js\"",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "8.57.0",
    "eslint": "8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "nodemon": "^3.1.4",
    "prettier": "3.8.4",
    "supertest": "^7.2.2",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1"
  }
