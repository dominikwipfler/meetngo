{
  "name": "meetngo",
  "version": "1.0.0",
  "private": true,
  "description": "MeetNGo – Event-App (Backend + Android Monorepo)",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --filter backend dev",
    "dev:backend": "pnpm --filter backend dev",
    "install:all": "pnpm install",
    "lint": "pnpm --filter backend lint",
    "lint:fix": "pnpm --filter backend lint:fix",
    "format": "pnpm --filter backend format",
    "test": "pnpm --filter backend test"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
